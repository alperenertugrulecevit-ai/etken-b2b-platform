generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id                 Int                      @id @default(autoincrement())
  code               String                   @unique
  barcode            String                   @unique
  name               String
  brand              String
  category           String
  supplier           String
  price              Float
  stock              Int
  reservedStock      Int                      @default(0)
  vat                Int
  ownStock           Boolean
  isActive           Boolean                  @default(true)
  createdAt          DateTime                 @default(now())
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements     StockMovement[]
  locationStocks     WarehouseLocationStock[]
  handlingUnitItems  HandlingUnitItem[]
  pickingRecords     PickingRecord[]
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id              Int             @id @default(autoincrement())
  name            String          @unique
  taxOffice       String?
  taxNumber       String?         @unique
  contactName     String?
  phone           String?
  email           String?
  address         String?
  city            String?
  district        String?
  postalCode      String?
  paymentTermDays Int             @default(0)
  discountRate    Float           @default(0)
  deliveryDays    Int             @default(1)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  purchaseOrders  PurchaseOrder[]
}

model Brand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id              Int               @id @default(autoincrement())
  customerCode    String            @unique
  companyName     String
  taxOffice       String?
  taxNumber       String?           @unique
  contactName     String?
  phone           String?
  email           String?
  address         String?
  city            String?
  district        String?
  paymentTermDays Int               @default(0)
  discountRate    Float             @default(0)
  creditLimit     Float             @default(0)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  addresses       CustomerAddress[]
  orders          Order[]
}

model CustomerAddress {
  id                Int      @id @default(autoincrement())
  customerId        Int
  title             String
  addressType       String
  contactName       String?
  phone             String?
  address           String
  city              String
  district          String
  postalCode        String?
  deliveryStartTime String?
  deliveryEndTime   String?
  hasForklift       Boolean  @default(false)
  rampCount         Int      @default(0)
  vehicleType       String?
  description       String?
  isDefault         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([customerId])
}

enum OrderStatus {
  DRAFT
  PENDING
  APPROVED
  PREPARING
  PICKING
  PACKING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id                Int         @id @default(autoincrement())
  orderNumber       String      @unique
  customerId        Int
  shippingAddressId Int?
  status            OrderStatus @default(PENDING)
  orderDate         DateTime    @default(now())
  requestedDate     DateTime?
  paymentTermDays   Int         @default(0)
  discountRate      Float       @default(0)
  subtotal          Float       @default(0)
  discountAmount    Float       @default(0)
  vatAmount         Float       @default(0)
  totalAmount       Float       @default(0)
  customerNote      String?
  internalNote      String?
  stockReserved     Boolean     @default(false)
  stockDeducted     Boolean     @default(false)
  stockReservedAt   DateTime?
  stockDeductedAt   DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  customer              Customer         @relation(fields: [customerId], references: [id])
  shippingAddress       CustomerAddress? @relation(fields: [shippingAddressId], references: [id])
  items                 OrderItem[]
  stockMovements        StockMovement[]
  pickingRecords        PickingRecord[]
  assignedHandlingUnits HandlingUnit[]   @relation("AssignedHandlingUnits")
  waveOrders            WaveOrder[]

  @@index([customerId])
  @@index([shippingAddressId])
  @@index([status])
  @@index([orderDate])
}

model OrderItem {
  id             Int      @id @default(autoincrement())
  orderId        Int
  productId      Int
  productCode    String
  productName    String
  quantity       Int
  pickedQuantity Int      @default(0)
  unitPrice      Float
  vatRate        Int
  lineNet        Float
  vatAmount      Float
  lineTotal      Float
  createdAt      DateTime @default(now())

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id])
  pickingRecords PickingRecord[]

  @@index([orderId])
  @@index([productId])
  @@index([pickedQuantity])
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id              Int                 @id @default(autoincrement())
  purchaseNumber  String              @unique
  supplierId      Int
  status          PurchaseOrderStatus @default(DRAFT)
  orderDate       DateTime            @default(now())
  expectedDate    DateTime?
  paymentTermDays Int                 @default(0)
  discountRate    Float               @default(0)
  subtotal        Float               @default(0)
  discountAmount  Float               @default(0)
  vatAmount       Float               @default(0)
  totalAmount     Float               @default(0)
  supplierNote    String?
  internalNote    String?
  approvedAt      DateTime?
  receivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  items          PurchaseOrderItem[]
  stockMovements StockMovement[]

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@index([expectedDate])
}

model PurchaseOrderItem {
  id               Int      @id @default(autoincrement())
  purchaseOrderId  Int
  productId        Int
  productCode      String
  productName      String
  orderedQuantity  Int
  receivedQuantity Int      @default(0)
  unitPrice        Float
  vatRate          Int
  lineNet          Float
  vatAmount        Float
  lineTotal        Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

enum StockMovementType {
  INITIAL_STOCK
  PURCHASE_RECEIPT
  MANUAL_IN
  MANUAL_OUT
  RESERVATION_CREATE
  RESERVATION_RELEASE
  SALE_SHIPMENT
  SALE_RETURN
  COUNT_INCREASE
  COUNT_DECREASE
  TRANSFER_IN
  TRANSFER_OUT
}

model StockMovement {
  id                    Int               @id @default(autoincrement())
  productId             Int
  orderId               Int?
  purchaseOrderId       Int?
  movementType          StockMovementType
  physicalChange        Int               @default(0)
  reservedChange        Int               @default(0)
  physicalBalanceAfter  Int
  reservedBalanceAfter  Int
  availableBalanceAfter Int
  documentNumber        String?
  description           String?
  createdAt             DateTime          @default(now())

  product       Product        @relation(fields: [productId], references: [id])
  order         Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([orderId])
  @@index([purchaseOrderId])
  @@index([movementType])
  @@index([createdAt])
}

enum WarehouseLocationType {
  PALLET
  BOX
  HANGING
  FLOOR
  RETURN
  QUALITY
  RFID
  SHIPPING
  RECEIVING
  QUARANTINE
}

model Warehouse {
  id            Int                 @id @default(autoincrement())
  code          String              @unique
  name          String
  address       String?
  city          String?
  district      String?
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  locations     WarehouseLocation[]
  handlingUnits HandlingUnit[]
}

model WarehouseLocation {
  id            Int                      @id @default(autoincrement())
  warehouseId   Int
  code          String
  aisle         String                   @default("")
  section       String                   @default("")
  level         String                   @default("")
  bin           String                   @default("")
  locationType  WarehouseLocationType    @default(PALLET)
  capacity      Int                      @default(1)
  sortOrder     Int                      @default(0)
  description   String?
  isActive      Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  stocks        WarehouseLocationStock[]
  handlingUnits HandlingUnit[]

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, code, aisle, section, level, bin], name: "warehouse_location_position_unique")
  @@index([warehouseId])
  @@index([code])
  @@index([aisle])
  @@index([locationType])
  @@index([isActive])
  @@index([sortOrder])
}

model WarehouseLocationStock {
  id            Int      @id @default(autoincrement())
  locationId    Int
  productId     Int
  quantity      Int      @default(0)
  reservedStock Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  location WarehouseLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product  Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId], name: "location_product_unique")
  @@index([locationId])
  @@index([productId])
  @@index([quantity])
}

enum HandlingUnitPurpose {
  STOCK
  PICKING
  PACKING
  SHIPPING
  RECEIVING
}

enum HandlingUnitType {
  PALLET
  BOX
  PICKING_PALLET
  PICKING_BOX
}

enum HandlingUnitStatus {
  OPEN
  CLOSED
  STORED
  IN_TRANSIT
  EMPTY
  CANCELLED
}

model HandlingUnit {
  id              Int                 @id @default(autoincrement())
  barcode         String              @unique
  unitType        HandlingUnitType
  purpose         HandlingUnitPurpose @default(STOCK)
  status          HandlingUnitStatus  @default(OPEN)
  warehouseId     Int?
  locationId      Int?
  parentUnitId    Int?
  assignedOrderId Int?
  description     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  warehouse Warehouse?         @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  location  WarehouseLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  parentUnit HandlingUnit?  @relation("HandlingUnitHierarchy", fields: [parentUnitId], references: [id], onDelete: SetNull)
  childUnits HandlingUnit[] @relation("HandlingUnitHierarchy")

  assignedOrder Order? @relation("AssignedHandlingUnits", fields: [assignedOrderId], references: [id], onDelete: SetNull)

  items HandlingUnitItem[]

  sourcePickingRecords PickingRecord[] @relation("PickingSourceHandlingUnit")
  targetPickingRecords PickingRecord[] @relation("PickingTargetHandlingUnit")

  @@index([barcode])
  @@index([unitType])
  @@index([purpose])
  @@index([status])
  @@index([warehouseId])
  @@index([locationId])
  @@index([parentUnitId])
  @@index([assignedOrderId])
}

model HandlingUnitItem {
  id             Int      @id @default(autoincrement())
  handlingUnitId Int
  productId      Int
  quantity       Int      @default(0)
  reservedStock  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  handlingUnit HandlingUnit @relation(fields: [handlingUnitId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([handlingUnitId, productId], name: "handling_unit_product_unique")
  @@index([handlingUnitId])
  @@index([productId])
  @@index([quantity])
}

model PickingRecord {
  id                   Int      @id @default(autoincrement())
  orderId              Int
  orderItemId          Int
  productId            Int
  sourceHandlingUnitId Int
  targetHandlingUnitId Int
  quantity             Int
  sourceQuantityAfter  Int
  targetQuantityAfter  Int
  createdAt            DateTime @default(now())

  order              Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem          OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  product            Product      @relation(fields: [productId], references: [id])
  sourceHandlingUnit HandlingUnit @relation("PickingSourceHandlingUnit", fields: [sourceHandlingUnitId], references: [id])
  targetHandlingUnit HandlingUnit @relation("PickingTargetHandlingUnit", fields: [targetHandlingUnitId], references: [id])

  @@index([orderId])
  @@index([orderItemId])
  @@index([productId])
  @@index([sourceHandlingUnitId])
  @@index([targetHandlingUnitId])
  @@index([createdAt])
}

/**
 * WMS İŞLEM VE HAREKET KAYITLARI
 * RF ve yönetim ekranlarında gerçekleştirilen depo işlemlerinin
 * ortak hareket geçmişini tutar.
 * Mevcut sistemde kullanıcı modeli bulunmadığı için operatorId,
 * operatorName ve terminalCode alanları metin olarak tutulur.
 */

enum WmsOperationType {
  RECEIVING
  HANDLING_UNIT_CREATE
  HANDLING_UNIT_UPDATE
  HANDLING_UNIT_CANCEL
  ADDRESSING
  UNADDRESSING
  ITEM_TRANSFER
  FULL_TRANSFER
  PALLET_LINK
  PALLET_UNLINK
  PICKING
  PACKING
  SHIPPING
  COUNT
  STOCK_IN
  STOCK_OUT
  OTHER
}

model WmsOperationLog {
  id Int @id @default(autoincrement())

  operationType WmsOperationType

  /**
   * İşlemin yapıldığı modül.
   * Örnekler:
   * RF_RECEIVING
   * RF_PICKING
   * RF_TRANSFER
   * ADMIN_HANDLING_UNIT
   */
  module String

  /**
   * İşlemin ana kayıt tipi ve kimliği.
   * Örnek:
   * entityType = HANDLING_UNIT
   * entityId   = 125
   */
  entityType String?
  entityId   Int?

  /**
   * Kullanıcı ve RF terminal bilgileri.
   * Kullanıcı altyapısı eklendiğinde operatorId alanı
   * kullanıcı kaydıyla ilişkilendirilebilir.
   */
  operatorId   String?
  operatorName String?
  terminalCode String?
  ipAddress    String?

  /**
   * İşlemle ilgili barkodlar.
   * barcode       = ana THM veya belge barkodu
   * sourceBarcode = kaynak THM
   * targetBarcode = hedef THM
   */
  barcode       String?
  sourceBarcode String?
  targetBarcode String?

  /**
   * Sipariş ve satın alma belgesi bilgileri.
   */
  orderId         Int?
  orderNumber     String?
  purchaseOrderId Int?
  purchaseNumber  String?

  /**
   * Ürün bilgileri.
   */
  productId   Int?
  productCode String?
  productName String?
  quantity    Int?

  /**
   * Depo ve lokasyon bilgileri.
   */
  warehouseId   Int?
  warehouseCode String?

  sourceLocationId   Int?
  sourceLocationCode String?

  targetLocationId   Int?
  targetLocationCode String?

  /**
   * İşlem öncesi ve sonrası durumlar.
   */
  previousStatus String?
  newStatus      String?

  /**
   * Serbest açıklama ve ilave teknik bilgi.
   * metadata örneği:
   * {
   * "sourceQuantityBefore": 10,
   * "sourceQuantityAfter": 6,
   * "targetQuantityBefore": 2,
   * "targetQuantityAfter": 6
   * }
   */
  description String?
  metadata    Json?

  /**
   * İşlem başarılı mı?
   * Başarısız RF girişimleri veya kullanıcı hataları da
   * ileride bu tabloya kaydedilebilir.
   */
  isSuccessful Boolean @default(true)
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([operationType])
  @@index([module])
  @@index([entityType, entityId])
  @@index([operatorId])
  @@index([operatorName])
  @@index([terminalCode])
  @@index([barcode])
  @@index([sourceBarcode])
  @@index([targetBarcode])
  @@index([orderId])
  @@index([orderNumber])
  @@index([purchaseOrderId])
  @@index([purchaseNumber])
  @@index([productId])
  @@index([productCode])
  @@index([warehouseId])
  @@index([sourceLocationId])
  @@index([targetLocationId])
  @@index([isSuccessful])
  @@index([createdAt])
}

// Bu blok mevcut prisma/schema.prisma dosyasının SONUNA eklenmelidir.
// Mevcut generator, datasource ve modeller silinmemelidir.

enum WaveStatus {
  DRAFT
  READY
  RELEASED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum WavePriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum WaveType {
  STORE_REPLENISHMENT
  CUSTOMER_ORDER
  ECOMMERCE
  TRANSFER
  MIXED
}

enum WaveAssignmentStatus {
  ASSIGNED
  ACTIVE
  WAITING
  COMPLETED
  CANCELLED
}

model Wave {
  id       String       @id @default(cuid())
  waveNo   String       @unique
  name     String?
  type     WaveType     @default(MIXED)
  status   WaveStatus   @default(DRAFT)
  priority WavePriority @default(NORMAL)

  plannedStartAt  DateTime?
  plannedFinishAt DateTime?
  releasedAt      DateTime?
  startedAt       DateTime?
  pausedAt        DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  plannedOrderCount Int @default(0)
  plannedLineCount  Int @default(0)
  plannedQuantity   Int @default(0)

  completedOrderCount Int @default(0)
  completedLineCount  Int @default(0)
  completedQuantity   Int @default(0)

  pickingProgress       Int @default(0)
  transferProgress      Int @default(0)
  consolidationProgress Int @default(0)
  packingProgress       Int @default(0)
  shippingProgress      Int @default(0)

  notes     String?
  createdBy String?
  updatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders      WaveOrder[]
  assignments WaveAssignment[]

  @@index([status, priority])
  @@index([plannedStartAt])
  @@index([createdAt])
}

model WaveOrder {
  id      String @id @default(cuid())
  waveId  String
  orderId Int

  /**
   * Sipariş numarası ve müşteri bilgileri operasyon anındaki
   * tarihsel görüntüyü korumak için snapshot olarak tutulur.
   */
  orderNumber  String
  customerCode String?
  customerName String?
  storeCode    String?
  storeName    String?

  lineCount         Int @default(0)
  plannedQuantity   Int @default(0)
  completedQuantity Int @default(0)

  isCompleted Boolean   @default(false)
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wave  Wave  @relation(fields: [waveId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  /**
   * Bir sipariş aynı Wave'e ikinci kez eklenemez.
   */
  @@unique([waveId, orderId], name: "wave_order_unique")
  @@index([orderId])
  @@index([orderNumber])
  @@index([waveId, isCompleted])
}

enum UserStatus {
  ACTIVE
  PASSIVE
  LOCKED
  SUSPENDED
}

enum UserType {
  ADMIN
  OFFICE
  WAREHOUSE
  RF_OPERATOR
  SYSTEM
  API
}

enum AuthSessionType {
  WEB
  RF
  API
}

model Employee {
  id String @id @default(cuid())

  employeeCode String @unique

  firstName String
  lastName  String

  email String? @unique
  phone String?

  department String?
  title      String?
  shiftCode  String?

  hireDate        DateTime?
  terminationDate DateTime?

  isActive Boolean @default(true)
  canUseRf Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User?

  @@index([isActive])
  @@index([canUseRf])
  @@index([department])
  @@index([firstName, lastName])
}

model User {
  id String @id @default(cuid())

  employeeId String? @unique

  username String  @unique
  email    String? @unique

  passwordHash String

  userType UserType   @default(WAREHOUSE)
  status   UserStatus @default(ACTIVE)

  mustChangePassword Boolean @default(true)
  failedLoginCount   Int     @default(0)

  lastLoginAt          DateTime?
  passwordChangedAt    DateTime?
  lockedAt             DateTime?
  lastFailedLoginAt    DateTime?
  sessionInvalidatedAt DateTime?

  isRfUser    Boolean @default(false)
  isAdminUser Boolean @default(false)

  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  createdBy    User?  @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[] @relation("UserCreatedBy")

  updatedBy    User?  @relation("UserUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedUsers User[] @relation("UserUpdatedBy")

  userRoles         UserRole[]
  assignedUserRoles UserRole[] @relation("UserRoleAssignedBy")

  waveAssignments   WaveAssignment[]
  assignedWaveTasks WaveAssignment[] @relation("WaveAssignmentAssignedBy")

  authSessions AuthSession[]

  @@index([employeeId])
  @@index([status])
  @@index([userType])
  @@index([isRfUser])
  @@index([isAdminUser])
  @@index([createdById])
  @@index([updatedById])
}

model AuthSession {
  id String @id @default(cuid())

  userId String

  /**
   * Gerçek oturum anahtarı veritabanında tutulmaz.
   * Yalnızca SHA-256 özeti saklanır.
   */
  tokenHash String @unique

  sessionType AuthSessionType @default(WEB)

  /**
   * RF oturumlarında cihaz veya terminal kodu.
   */
  terminalCode String?

  /**
   * İstek kaynağına ait teknik bilgiler.
   */
  ipAddress String?
  userAgent String?

  /**
   * Oturumun son geçerlilik zamanı.
   */
  expiresAt DateTime

  /**
   * Kullanıcının en son aktif olduğu zaman.
   */
  lastActivityAt DateTime @default(now())

  /**
   * Oturum kullanıcı çıkışı veya yönetici işlemiyle
   * geçersiz kılındığında doldurulur.
   */
  revokedAt    DateTime?
  revokeReason String?
  revokedById  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionType])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([lastActivityAt])
  @@index([terminalCode])
}

model Role {
  id String @id @default(cuid())

  code String @unique
  name String @unique

  description String?

  isSystemRole Boolean @default(false)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([isActive])
  @@index([isSystemRole])
}

model Permission {
  id String @id @default(cuid())

  code String @unique
  name String

  module      String
  description String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rolePermissions RolePermission[]

  @@index([module])
  @@index([isActive])
}

model UserRole {
  id String @id @default(cuid())

  userId String
  roleId String

  assignedById String?
  assignedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedBy User? @relation("UserRoleAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId], name: "user_role_unique")
  @@index([userId])
  @@index([roleId])
  @@index([assignedById])
}

model RolePermission {
  id String @id @default(cuid())

  roleId       String
  permissionId String

  grantedAt DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId], name: "role_permission_unique")
  @@index([roleId])
  @@index([permissionId])
}

model WaveAssignment {
  id String @id @default(cuid())

  waveId String
  userId String

  operationType WmsOperationType?
  status        WaveAssignmentStatus @default(ASSIGNED)

  assignedAt     DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  lastActivityAt DateTime?

  assignedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wave Wave @relation(fields: [waveId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  assignedBy User? @relation("WaveAssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([waveId, userId, operationType], name: "wave_user_operation_unique")
  @@index([waveId, status])
  @@index([userId, status])
  @@index([assignedById])
  @@index([operationType])
}
