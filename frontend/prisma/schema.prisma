generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id                 Int                      @id @default(autoincrement())
  code               String                   @unique
  barcode            String                   @unique
  name               String
  brand              String
  category           String
  supplier           String
  price              Float
  stock              Int
  reservedStock      Int                      @default(0)
  vat                Int
  ownStock           Boolean
  isActive           Boolean                  @default(true)
  createdAt          DateTime                 @default(now())
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements     StockMovement[]
  locationStocks     WarehouseLocationStock[]
  handlingUnitItems  HandlingUnitItem[]
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id              Int             @id @default(autoincrement())
  name            String          @unique
  taxOffice       String?
  taxNumber       String?         @unique
  contactName     String?
  phone           String?
  email           String?
  address         String?
  city            String?
  district        String?
  postalCode      String?
  paymentTermDays Int             @default(0)
  discountRate    Float           @default(0)
  deliveryDays    Int             @default(1)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  purchaseOrders  PurchaseOrder[]
}

model Brand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id              Int               @id @default(autoincrement())
  customerCode    String            @unique
  companyName     String
  taxOffice       String?
  taxNumber       String?           @unique
  contactName     String?
  phone           String?
  email           String?
  address         String?
  city            String?
  district        String?
  paymentTermDays Int               @default(0)
  discountRate    Float             @default(0)
  creditLimit     Float             @default(0)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  addresses       CustomerAddress[]
  orders          Order[]
}

model CustomerAddress {
  id                Int      @id @default(autoincrement())
  customerId        Int
  title             String
  addressType       String
  contactName       String?
  phone             String?
  address           String
  city              String
  district          String
  postalCode        String?
  deliveryStartTime String?
  deliveryEndTime   String?
  hasForklift       Boolean  @default(false)
  rampCount         Int      @default(0)
  vehicleType       String?
  description       String?
  isDefault         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([customerId])
}

enum OrderStatus {
  DRAFT
  PENDING
  APPROVED
  PREPARING
  PICKING
  PACKING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id                Int         @id @default(autoincrement())
  orderNumber       String      @unique
  customerId        Int
  shippingAddressId Int?
  status            OrderStatus @default(PENDING)
  orderDate         DateTime    @default(now())
  requestedDate     DateTime?
  paymentTermDays   Int         @default(0)
  discountRate      Float       @default(0)
  subtotal          Float       @default(0)
  discountAmount    Float       @default(0)
  vatAmount         Float       @default(0)
  totalAmount       Float       @default(0)
  customerNote      String?
  internalNote      String?
  stockReserved     Boolean     @default(false)
  stockDeducted     Boolean     @default(false)
  stockReservedAt   DateTime?
  stockDeductedAt   DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  customer        Customer         @relation(fields: [customerId], references: [id])
  shippingAddress CustomerAddress? @relation(fields: [shippingAddressId], references: [id])
  items           OrderItem[]
  stockMovements  StockMovement[]

  @@index([customerId])
  @@index([shippingAddressId])
  @@index([status])
  @@index([orderDate])
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  productId   Int
  productCode String
  productName String
  quantity    Int
  unitPrice   Float
  vatRate     Int
  lineNet     Float
  vatAmount   Float
  lineTotal   Float
  createdAt   DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id              Int                 @id @default(autoincrement())
  purchaseNumber  String              @unique
  supplierId      Int
  status          PurchaseOrderStatus @default(DRAFT)
  orderDate       DateTime            @default(now())
  expectedDate    DateTime?
  paymentTermDays Int                 @default(0)
  discountRate    Float               @default(0)
  subtotal        Float               @default(0)
  discountAmount  Float               @default(0)
  vatAmount       Float               @default(0)
  totalAmount     Float               @default(0)
  supplierNote    String?
  internalNote    String?
  approvedAt      DateTime?
  receivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  items          PurchaseOrderItem[]
  stockMovements StockMovement[]

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@index([expectedDate])
}

model PurchaseOrderItem {
  id               Int      @id @default(autoincrement())
  purchaseOrderId  Int
  productId        Int
  productCode      String
  productName      String
  orderedQuantity  Int
  receivedQuantity Int      @default(0)
  unitPrice        Float
  vatRate          Int
  lineNet          Float
  vatAmount        Float
  lineTotal        Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

enum StockMovementType {
  INITIAL_STOCK
  PURCHASE_RECEIPT
  MANUAL_IN
  MANUAL_OUT
  RESERVATION_CREATE
  RESERVATION_RELEASE
  SALE_SHIPMENT
  SALE_RETURN
  COUNT_INCREASE
  COUNT_DECREASE
  TRANSFER_IN
  TRANSFER_OUT
}

model StockMovement {
  id                    Int               @id @default(autoincrement())
  productId             Int
  orderId               Int?
  purchaseOrderId       Int?
  movementType          StockMovementType
  physicalChange        Int               @default(0)
  reservedChange        Int               @default(0)
  physicalBalanceAfter  Int
  reservedBalanceAfter  Int
  availableBalanceAfter Int
  documentNumber        String?
  description           String?
  createdAt             DateTime          @default(now())

  product       Product        @relation(fields: [productId], references: [id])
  order         Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([orderId])
  @@index([purchaseOrderId])
  @@index([movementType])
  @@index([createdAt])
}

enum WarehouseLocationType {
  PALLET
  BOX
  HANGING
  FLOOR
  RETURN
  QUALITY
  RFID
  SHIPPING
  RECEIVING
  QUARANTINE
}

model Warehouse {
  id            Int                 @id @default(autoincrement())
  code          String              @unique
  name          String
  address       String?
  city          String?
  district      String?
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  locations     WarehouseLocation[]
  handlingUnits HandlingUnit[]
}

model WarehouseLocation {
  id            Int                      @id @default(autoincrement())
  warehouseId   Int
  code          String
  aisle         String                   @default("")
  section       String                   @default("")
  level         String                   @default("")
  bin           String                   @default("")
  locationType  WarehouseLocationType    @default(PALLET)
  capacity      Int                      @default(1)
  sortOrder     Int                      @default(0)
  description   String?
  isActive      Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  stocks        WarehouseLocationStock[]
  handlingUnits HandlingUnit[]

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, code, aisle, section, level, bin], name: "warehouse_location_position_unique")
  @@index([warehouseId])
  @@index([code])
  @@index([aisle])
  @@index([locationType])
  @@index([isActive])
  @@index([sortOrder])
}

model WarehouseLocationStock {
  id            Int      @id @default(autoincrement())
  locationId    Int
  productId     Int
  quantity      Int      @default(0)
  reservedStock Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  location WarehouseLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product  Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId], name: "location_product_unique")
  @@index([locationId])
  @@index([productId])
  @@index([quantity])
}

enum HandlingUnitType {
  PALLET
  BOX
}

enum HandlingUnitStatus {
  OPEN
  CLOSED
  STORED
  IN_TRANSIT
  EMPTY
  CANCELLED
}

model HandlingUnit {
  id           Int                @id @default(autoincrement())
  barcode      String             @unique
  unitType     HandlingUnitType
  status       HandlingUnitStatus @default(OPEN)
  warehouseId  Int?
  locationId   Int?
  parentUnitId Int?
  description  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  warehouse Warehouse?         @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  location  WarehouseLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  parentUnit HandlingUnit?  @relation("HandlingUnitHierarchy", fields: [parentUnitId], references: [id], onDelete: SetNull)
  childUnits HandlingUnit[] @relation("HandlingUnitHierarchy")

  items HandlingUnitItem[]

  @@index([barcode])
  @@index([unitType])
  @@index([status])
  @@index([warehouseId])
  @@index([locationId])
  @@index([parentUnitId])
}

model HandlingUnitItem {
  id             Int      @id @default(autoincrement())
  handlingUnitId Int
  productId      Int
  quantity       Int      @default(0)
  reservedStock  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  handlingUnit HandlingUnit @relation(fields: [handlingUnitId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([handlingUnitId, productId], name: "handling_unit_product_unique")
  @@index([handlingUnitId])
  @@index([productId])
  @@index([quantity])
}
